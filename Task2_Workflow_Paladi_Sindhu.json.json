      "parameters": {
        "jsCode": "// Evaluate HTTP response from attempt 1\nconst ctx  = $('Init Check Context').first().json;\nconst resp = $input.first().json;\n\nconst statusCode   = resp.statusCode ?? resp.status ?? 0;\nconst responseTime = resp.headers?.['x-response-time'] \n                     ? parseInt(resp.headers['x-response-time']) \n                     : null;  // Approximation — real timing needs Benchmark node\nconst isUp         = statusCode >= 200 && statusCode < 300;\nconst hasError     = !!resp.error;\n\nreturn [{\n  json: {\n    ...ctx,\n    status_code:    statusCode,\n    is_up:          isUp && !hasError,\n    has_error:      hasError,\n    error_message:  resp.error?.message ?? null,\n    attempt:        1,\n    needs_retry:    (!isUp || hasError)\n  }\n}];\n"
