    {
      "parameters": {
        "jsCode": "// Build daily uptime summary\nconst rows = $input.all().map(i => i.json);\nconst today = new Date().toISOString().split('T')[0];\nconst todayRows = rows.filter(r => r.Date === today);\n\nconst total   = todayRows.length;\nconst upCount = todayRows.filter(r => r.Is_Up === 'UP').length;\nconst downCount = total - upCount;\nconst uptimePct = total > 0 ? ((upCount / total) * 100).toFixed(2) : 'N/A';\n\nconst avgAttempts = total > 0\n  ? (todayRows.reduce((s, r) => s + Number(r.Attempts_Used || 1), 0) / total).toFixed(1)\n  : 'N/A';\n\nconst status = parseFloat(uptimePct) >= 99 ? '✅ Healthy'\n             : parseFloat(uptimePct) >= 95 ? '⚠️ Degraded'\n             : '❌ Critical';\n\nconst msg = [\n  `📊 *Daily Uptime Report — ${today}*`,\n  ``,\n  `🌐 Target: https://demo.realworld.io`,\n  ``,\n  `✅ Checks Passed:  ${upCount} / ${total}`,\n  `❌ Checks Failed:  ${downCount}`,\n  `📈 Uptime:         ${uptimePct}%`,\n  `🔁 Avg Retries:   ${avgAttempts}`,\n  ``,\n  `Status: ${status}`,\n  ``,\n  `_Report generated at ${new Date().toUTCString()}_`\n].join('\\n');\n\nreturn [{ json: { telegram_message: msg, uptime_pct: uptimePct, date: today } }];\n"
      },
