    {
      "parameters": {
        "jsCode": "// Keep only the top 5 coins by market cap rank\nconst coins = $input.all();\nconst items = coins[0].json;\n\nif (!Array.isArray(items)) {\n  throw new Error('CoinGecko response is not an array — possible rate limit or API error');\n}\n\nconst top5 = items\n  .sort((a, b) => a.market_cap_rank - b.market_cap_rank)\n  .slice(0, 5);\n\n// Return each coin as a separate item and persist full list in top item\nconst result = top5.map((coin, idx) => ({\n  json: {\n    rank:                coin.market_cap_rank,\n    id:                  coin.id,\n    symbol:              coin.symbol.toUpperCase(),\n    name:                coin.name,\n    current_price:       coin.current_price,\n    market_cap:          coin.market_cap,\n    price_change_24h_pct: coin.price_change_percentage_24h,\n    volume_24h:          coin.total_volume,\n    image:               coin.image,\n    is_top1:             idx === 0,\n    top5_summary:        idx === 0 ? top5.map(c =>\n      `#${c.market_cap_rank} ${c.symbol.toUpperCase()}: $${c.current_price.toLocaleString()} (${c.price_change_percentage_24h?.toFixed(2)}%)`\n    ).join('\\n') : null\n  }\n}));\n\nreturn result;\n"
      },
