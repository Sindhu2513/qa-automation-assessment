        "jsCode": "// Build NORMAL UPDATE Telegram message\nconst d = $input.first().json;\nconst emoji = d.change24h >= 0 ? '🟢' : '🔴';\n\nconst msg = [\n  `${emoji} *Market Update — ${d.name} (${d.symbol})*`,\n  ``,\n  `💰 Price:       \\$${d.price.toLocaleString()}`,\n  `📊 24h Change:  ${d.change24h_formatted}`,\n  `📊 24h High:    \\$${d.high24h.toLocaleString()}`,\n  `📉 24h Low:     \\$${d.low24h.toLocaleString()}`,\n  `💎 Market Cap:  \\$${(d.market_cap / 1e9).toFixed(2)}B`,\n  `📦 Volume 24h:  \\$${(d.volume_24h / 1e9).toFixed(2)}B`,\n  ``,\n  `ℹ️  No significant movement (< 5% change in last 24h)`,\n  ``,\n  `🕐 ${new Date(d.timestamp).toUTCString()}`\n].join('\\n');\n\nreturn [{ json: { telegram_message: msg, alert_type: 'NORMAL', ...d } }];\n"
