    {
      "parameters": {
        "jsCode": "// Merge detail data with top5 summary from upstream\nconst detail = $input.first().json;\nconst md = detail.market_data;\n\nconst change24h = md?.price_change_percentage_24h ?? 0;\nconst price     = md?.current_price?.usd ?? 0;\nconst high24h   = md?.high_24h?.usd ?? 0;\nconst low24h    = md?.low_24h?.usd ?? 0;\nconst ath       = md?.ath?.usd ?? 0;\nconst athChange = md?.ath_change_percentage?.usd ?? 0;\nconst volume    = md?.total_volume?.usd ?? 0;\nconst mcap      = md?.market_cap?.usd ?? 0;\n\nconst sign = change24h >= 0 ? '+' : '';\n\nreturn [{\n  json: {\n    coin_id:     detail.id,\n    symbol:      detail.symbol?.toUpperCase(),\n    name:        detail.name,\n    price,\n    change24h,\n    change24h_formatted: `${sign}${change24h.toFixed(2)}%`,\n    high24h,\n    low24h,\n    ath,\n    ath_change_pct: athChange.toFixed(2),\n    volume_24h:  volume,\n    market_cap:  mcap,\n    is_bullish:  change24h > 5,\n    description: detail.description?.en?.slice(0, 200) ?? '',\n    timestamp:   new Date().toISOString()\n  }\n}];\n"
      },
